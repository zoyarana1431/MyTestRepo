SECRET_KEY=generate-a-long-random-string
DATABASE_URL=postgresql+psycopg2://qatm:qatm@localhost:5432/qatm
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (optional frontend/.env.local)
# Leave NEXT_PUBLIC_API_URL unset during `npm run dev` so the app calls /api on the
# same origin and Next.js proxies to the API (see frontend/next.config.mjs).
NEXT_PUBLIC_API_URL=http://localhost:8000
# Used only for server-side fetches when NEXT_PUBLIC_API_URL is unset (rare).
API_PROXY_TARGET=http://127.0.0.1:8000
